package com.example.restservice;

import com.fasterxml.jackson.annotation.JsonProperty;

public class Vaca {
    private long num;
    private String nombre;
    private String numeroHierro;
    private String numeroCrotal;
    private String anioNacimiento;
    private String finca;
    private byte[] foto;

    public Vaca() {}

    public Vaca(long num, String nombre, String numeroHierro, 
               String numeroCrotal, String anioNacimiento, 
               String finca, byte[] foto) {
        this.num = num;
        this.nombre = nombre;
        this.numeroHierro = numeroHierro;
        this.numeroCrotal = numeroCrotal;
        this.anioNacimiento = anioNacimiento;
        this.finca = finca;
        this.foto = foto;
    }

    @JsonProperty
    public long getNum() { return num; }
    @JsonProperty
    public void setNum(long num) { this.num = num; }

    @JsonProperty
    public String getNombre() { return nombre; }
    @JsonProperty
    public void setNombre(String nombre) { this.nombre = nombre; }

    @JsonProperty("numero_hierro")
    public String getNumeroHierro() { return numeroHierro; }
    @JsonProperty("numero_hierro")
    public void setNumeroHierro(String numeroHierro) { this.numeroHierro = numeroHierro; }

    @JsonProperty("numero_crotal")
    public String getNumeroCrotal() { return numeroCrotal; }
    @JsonProperty("numero_crotal")
    public void setNumeroCrotal(String numeroCrotal) { this.numeroCrotal = numeroCrotal; }

    @JsonProperty("anio_nacimiento")
    public String getAnioNacimiento() { return anioNacimiento; }
    @JsonProperty("anio_nacimiento")
    public void setAnioNacimiento(String anioNacimiento) { this.anioNacimiento = anioNacimiento; }

    @JsonProperty
    public String getFinca() { return finca; }
    @JsonProperty
    public void setFinca(String finca) { this.finca = finca; }

    @JsonProperty
    public byte[] getFoto() { return foto; }
    @JsonProperty
    public void setFoto(byte[] foto) { this.foto = foto; }
}
