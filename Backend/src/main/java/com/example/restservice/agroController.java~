    // Métodos PUT y DELETE para Toros y Chotos siguen el mismo patrón
    // En AgroController.java
    @PutMapping("/chotos/{num}/foto")
    public ResponseEntity<String> actualizarFotoChoto(
						      @PathVariable("num") int num,
						      @RequestBody String fotoBase64) {

	System.out.println("\n>>> Petición PUT recibida en /api/choto/" + num + "/foto");
	System.out.println(">>> Longitud del Base64 recibido: " + fotoBase64.length() + " caracteres");

	try {
	    // Decodificar Base64
	    byte[] fotoBytes = Base64.getDecoder().decode(fotoBase64);
	    System.out.println(">>> Tamaño de la imagen decodificada: " + fotoBytes.length + " bytes");

	    String sql = "UPDATE chotos SET foto = ? WHERE num = ?";
	    System.out.println(">>> Ejecutando query: " + sql);

	    try (Connection conn = DriverManager.getConnection(DB_URL, DB_USER, DB_PASSWORD);
		 PreparedStatement pstmt = conn.prepareStatement(sql)) {

		pstmt.setBytes(1, fotoBytes);
		pstmt.setInt(2, num);

		int result = pstmt.executeUpdate();
		System.out.println(">>> Filas afectadas: " + result);

		if (result > 0) {
		    System.out.println(">>> Éxito: Foto actualizada para choto " + num);
		    return ResponseEntity.ok().body("Foto del choto " + num + " actualizada correctamente");
		} else {
		    System.out.println(">>> Advertencia: No existe choto con num: " + num);
		    return ResponseEntity.status(HttpStatus.NOT_FOUND)
                        .body("No se encontró ningún choto con número: " + num);
		}

	    } catch (SQLException e) {
		System.err.println(">>> Error SQL al actualizar foto:");
		e.printStackTrace();
		return ResponseEntity.internalServerError()
                    .body("Error interno al procesar la solicitud. Detalles: " + e.getMessage());
	    }

	} catch (IllegalArgumentException e) {
	    System.err.println(">>> Error: Base64 inválido");
	    e.printStackTrace();
	    return ResponseEntity.badRequest()
                .body("Formato de imagen inválido. Error: " + e.getMessage());
	}
    }


    @PostMapping("/chotos")
    public ResponseEntity<Choto> crearChoto(@RequestBody Choto choto) { // Cambiar a Choto como tipo de retorno
	String sqlInsert = "INSERT INTO chotos (nombre, numero_crotal, sexo, peso, finca, foto) "
	    + "VALUES (?, ?, ?, ?, ?, ?)";
    
	try (Connection conn = DriverManager.getConnection(DB_URL, DB_USER, DB_PASSWORD);
	     PreparedStatement pstmt = conn.prepareStatement(sqlInsert, Statement.RETURN_GENERATED_KEYS)) { // Para obtener el ID generado

	    byte[] fotoBytes = choto.getFoto() != null && !choto.getFoto().isEmpty() 
		? Base64.getDecoder().decode(choto.getFoto()) 
		: new byte[0];

	    pstmt.setString(1, choto.getNombre());
	    pstmt.setString(2, choto.getNumeroCrotal());
	    pstmt.setString(3, choto.getSexo());
	    pstmt.setDouble(4, choto.getPeso());
	    pstmt.setString(5, choto.getFinca());
	    pstmt.setBytes(6, fotoBytes);

	    int result = pstmt.executeUpdate();
        
	    if (result > 0) {
		// Obtener el ID generado
		ResultSet generatedKeys = pstmt.getGeneratedKeys();
		if (generatedKeys.next()) {
		    long idGenerado = generatedKeys.getLong(1);
                
		    // Obtener el choto completo
		    String sqlSelect = "SELECT * FROM chotos WHERE num = ?";
		    try (PreparedStatement pstmtSelect = conn.prepareStatement(sqlSelect)) {
			pstmtSelect.setLong(1, idGenerado);
			ResultSet rs = pstmtSelect.executeQuery();
                    
			if (rs.next()) {
			    Choto chotoCreado = new Choto();
			    chotoCreado.setNum(rs.getLong("num"));
			    chotoCreado.setNombre(rs.getString("nombre"));
			    chotoCreado.setNumeroCrotal(rs.getString("numero_crotal"));
			    chotoCreado.setSexo(rs.getString("sexo"));
			    chotoCreado.setPeso(rs.getDouble("peso"));
			    chotoCreado.setFinca(rs.getString("finca"));
                        
			    // Convertir bytes a Base64
			    byte[] fotoBytesBD = rs.getBytes("foto");
			    if (fotoBytesBD != null) {
				chotoCreado.setFoto(Base64.getEncoder().encodeToString(fotoBytesBD));
			    }
                        
			    return new ResponseEntity<>(chotoCreado, HttpStatus.CREATED);
			}
		    }
		}
		return new ResponseEntity<>(HttpStatus.INTERNAL_SERVER_ERROR);
	    }
	    return new ResponseEntity<>(HttpStatus.BAD_REQUEST);
        
	} catch (SQLException | IllegalArgumentException e) {
	    e.printStackTrace();
	    return new ResponseEntity<>(HttpStatus.INTERNAL_SERVER_ERROR);
	}
    }





