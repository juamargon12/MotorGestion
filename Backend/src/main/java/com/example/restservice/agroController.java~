    // ================== CHOTOS ================== 
    @GetMapping("/chotos")
    public ResponseEntity<List<Choto>> getAllChotos() {
	System.out.println(">>> Petición GET recibida en /api/chotos");
		
	List<Choto> chotos = new ArrayList<>();
	String sql = "SELECT * FROM chotos";
		
	try (Connection conn = DriverManager.getConnection(DB_URL, DB_USER, DB_PASSWORD);
	     Statement stmt = conn.createStatement();
	     ResultSet rs = stmt.executeQuery(sql)) {
		    
	    System.out.println("Conexión a BD establecida. Ejecutando query...");
		    
	    while (rs.next()) {
		Choto choto = new Choto();
		// Mapear todos los campos
		choto.setNum(rs.getLong("num"));
		choto.setNombre(rs.getString("nombre"));
		choto.setNumeroCrotal(rs.getString("numero_crotal"));
		choto.setSexo(rs.getString("sexo"));
		choto.setPeso(rs.getDouble("peso"));
		choto.setFinca(rs.getString("finca"));
		        
		// Convertir bytes a Base64
		byte[] fotoBytes = rs.getBytes("foto");
		if (fotoBytes != null) {
		    choto.setFoto(Base64.getEncoder().encodeToString(fotoBytes));
		} else {
		    choto.setFoto(null);
		}
		        
		chotos.add(choto);
		System.out.println("Choto encontrado: " + choto.getNombre());
	    }
		    
	    System.out.println("Total de chotos recuperados: " + chotos.size());
	    return new ResponseEntity<>(chotos, HttpStatus.OK);
		    
	} catch (SQLException e) {
	    System.err.println("ERROR en getAllChotos:");
	    e.printStackTrace();
	    return new ResponseEntity<>(HttpStatus.INTERNAL_SERVER_ERROR);
	}
    }

    

    @GetMapping("/choto/{num}")
