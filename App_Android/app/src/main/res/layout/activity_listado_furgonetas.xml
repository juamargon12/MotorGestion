<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Barra de búsqueda — filtra la lista en tiempo real (Tema 03) -->
    <EditText
        android:id="@+id/etBuscar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="🔍 Buscar furgoneta por modelo..."
        android:padding="10dp"
        android:inputType="text" />

    <Button
        android:id="@+id/btnNuevaFurgoneta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Añadir Nueva Furgoneta" />

    <!-- Aviso de modo offline (Tema 04 — Persistencia) -->
    <TextView
        android:id="@+id/tvAvisoOffline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚠ MODO OFFLINE — Datos en caché. Solo lectura."
        android:textColor="#FFFFFF"
        android:textAlignment="center"
        android:padding="10dp"
        android:background="#C62828"
        android:visibility="gone" />

    <ListView
        android:id="@+id/listaListView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
</LinearLayout>
